# ── AI Provider ────────────────────────────────────────────────────────────────
# ACTIVE: Ollama (local GGUF model — fully offline AI)
# Model loaded via: python test_edulens.py  (from EduLens root)

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=edulens

# BACKUP: Groq cloud (uncomment + swap provider line in aiService.ts to use)
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama3-70b-8192

# ── Server ──────────────────────────────────────────────────────────────────────
PORT=3001

# ── Database ────────────────────────────────────────────────────────────────────
# Leave empty to use default (userData dir in Electron, ./data/ standalone)
DB_PATH=

# ── Teacher Auth ────────────────────────────────────────────────────────────────
DEFAULT_TEACHER_PIN=1234
